# =============================================================================
# Nioh 2 Build Forge — Environment Variables
#
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control — it contains secret keys.
#
# HOW TO GET THESE VALUES:
#   SUPABASE: Go to supabase.com → your project → Settings → API
#   ANTHROPIC: Go to console.anthropic.com → API Keys → Create key
# =============================================================================

# Supabase — the database layer (public values, safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — the AI layer (SECRET — never expose this in the browser)
# This key should only be used in server-side API routes, never in client code.
ANTHROPIC_API_KEY=sk-ant-your-key-here
